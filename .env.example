# ============================================================================
# LLM CONFIGURATION
# ============================================================================
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_API_KEY=your_openrouter_key
OPENAI_MODEL_NAME=openrouter/openai/gpt-4o-mini

# ============================================================================
# DATABASE
# ============================================================================
# Path to SQLite RCM database (default: data/rcm.db)
RCM_DB_PATH=data/rcm.db

# ============================================================================
# OBSERVABILITY & TRACING
# ============================================================================
# Log format: "json" or "human" (default: human)
RCM_AGENT_LOG_FORMAT=human
# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
RCM_AGENT_LOG_LEVEL=INFO

# LangSmith (https://smith.langchain.com)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=rcm-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ============================================================================
# ESCALATION (HITL) CONFIGURATION
# ============================================================================
# Confidence threshold below which encounter is escalated (0.0-1.0, default: 0.85)
ESCALATION_CONFIDENCE_THRESHOLD=0.85
# Charge amount above which encounter is escalated (default: 5000)
ESCALATION_HIGH_VALUE_THRESHOLD=5000
# Always escalate oncology encounters (default: true)
ESCALATION_ONCOLOGY_FLAG=true
# Escalate when clinical notes or documents are missing (default: true)
ESCALATION_INCOMPLETE_DATA_FLAG=true

# ============================================================================
# PRIOR AUTH
# ============================================================================
# Comma-separated CPT codes that require prior authorization (e.g. 73721,70450)
AUTH_REQUIRED_CPT_CODES=73721,70450,72148

# ============================================================================
# RAG
# ============================================================================
# Backend: "mock" (canned snippets) or "rag" (medicare_rag ChromaDB)
RCM_RAG_BACKEND=mock
# Path to ChromaDB directory (used when RCM_RAG_BACKEND=rag; default: ~/medicare_rag/data/chroma)
RCM_RAG_CHROMA_DIR=/home/chris/medicare_rag/data/chroma
# Legacy: path to RAG corpus (payer policies, coding guidelines)
RCM_RAG_CORPUS_PATH=data/rag_corpus

# ============================================================================
# TOKEN BUDGETS & RATE LIMITS
# ============================================================================
RCM_AGENT_MAX_TOKENS=100000
RCM_AGENT_MAX_LLM_CALLS=50

# CrewAI verbose mode (default: true)
CREWAI_VERBOSE=true
